{
    "name": "avadim/evotor-php-sdk",
    "description": "Evotor PHP SDK",
    "keywords": ["evotor", "php", "api" ,"sdk"],
    "type": "library",
    "license": "MIT",
	"autoload": {
		"psr-4": {"avadim\\Evotor\\": "src/Evotor"}
	},
    "authors": [
        {
            "name": "Alexander Bogdanov",
            "email": "ab@dev.kily.ru"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "7.4.33"
        }
    }
}
